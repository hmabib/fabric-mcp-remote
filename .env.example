# Azure Service Principal credentials (required)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# MCP API Key for client authentication (required)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=your-generated-api-key

# Optional: FastMCP configuration
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000

# Optional: Fabric API configuration
MCP_LOG_LEVEL=INFO
FABRIC_API_CALL_TIMEOUT=60
